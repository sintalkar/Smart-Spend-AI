rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'v90369@gmail.com' && request.auth.token.email_verified == true);
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Subcollections
      match /transactions/{id} { allow read, write: if isOwner(userId); }
      match /categories/{id} { allow read, write: if isOwner(userId); }
      match /budgets/{id} { allow read, write: if isOwner(userId); }
      
      // Generic catch-all for any other nested data for this user
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Allow listing all users for admins
    match /users {
      allow list: if isAdmin();
    }

    // Connection test doc
    match /test/connection {
      allow read: if true;
    }
  }
}
